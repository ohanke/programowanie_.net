<Window x:Class="CodeEngineUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Concurrent Code Engine" Height="600" Width="900">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock DockPanel.Dock="Top" Text="Code Editor (C#):" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="CodeEditor" AcceptsReturn="True" AcceptsTab="True" 
                     FontFamily="Consolas" FontSize="12" VerticalScrollBarVisibility="Auto"/>
        </DockPanel>

        <StackPanel Grid.Column="1">
            <GroupBox Header="Settings" Margin="0,0,0,10">
                <StackPanel Margin="5">
                    <TextBlock Text="Max Concurrent Tasks:"/>
                    <TextBox x:Name="TaskCountInput" Text="8" Margin="0,5"/>

                    <TextBlock Text="Resource Limit:"/>
                    <TextBox x:Name="ResourceLimitInput" Text="3" Margin="0,5"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Controls" Margin="0,0,0,10">
                <UniformGrid Columns="2" Margin="5">
                    <Button x:Name="BtnStart" Content="Start" Margin="2" Click="BtnStart_Click"/>
                    <Button x:Name="BtnStop" Content="Stop" Margin="2" Click="BtnStop_Click"/>
                    <Button x:Name="BtnPause" Content="Pause/Resume" Margin="2" Click="BtnPause_Click"/>
                    <Button x:Name="BtnExit" Content="Exit" Margin="2" IsEnabled="False" Click="BtnExit_Click"/>
                </UniformGrid>
            </GroupBox>

            <TextBlock Text="Execution Progress:" FontWeight="Bold" Margin="0,5"/>
            <ProgressBar x:Name="MainProgressBar" Height="20" Margin="0,0,0,10"/>

            <TextBlock Text="Active Tasks Status:" FontWeight="Bold" Margin="0,5"/>
            <ListView x:Name="TasksListView" Height="200">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ID" DisplayMemberBinding="{Binding Id}" Width="40"/>
                        <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Type}" Width="60"/>
                        <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="150"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </StackPanel>
    </Grid>
</Window>